# MongoDB Atlas Configuration
# Get this from your MongoDB Atlas cluster -> Connect -> Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chauchaublingstore-database?retryWrites=true&w=majority&ssl=true&tls=true

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Next.js Configuration
NODE_ENV=development
